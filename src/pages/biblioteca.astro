---
import LayoutBase from '../layouts/LayoutBase.astro';
import dadosBiblioteca from '../data/biblioteca.json';
---

<LayoutBase mostrarBotaoVoltar={true}>
    <div class="flex flex-col gap-6 md:gap-7 lg:gap-8 max-w-full md:max-w-4xl lg:max-w-6xl w-full mx-auto pb-12 md:pb-16 px-2 md:px-4 lg:px-6">
        <a href={dadosBiblioteca.linkAcervo.url} target="_blank" class="text-white bg-[#BC1823] rounded-[20px] p-6 md:p-7 flex justify-between items-center gap-4 group shadow-sm hover:bg-[#a0141d] transition-colors">
            <div class="pr-2 md:pr-4">
                <h2 class="font-bold text-lg md:text-2xl leading-tight mb-1">{dadosBiblioteca.linkAcervo.titulo}</h2>
                <p class="text-white/80 text-xs md:text-sm font-light leading-tight mt-2">{dadosBiblioteca.linkAcervo.subtitulo}</p>
            </div>
            <i class="fa-solid fa-arrow-right text-2xl md:text-3xl"></i>
        </a>

        <div class="bg-gray-50 border border-gray-100 rounded-[20px] p-6 md:p-7 flex flex-col items-start shadow-sm">
            <h3 class="text-sm md:text-base text-gray-500 font-bold mb-5 uppercase">Horário de Funcionamento</h3>
            <div class="flex flex-col gap-4 items-center px-1 md:px-2 w-full">
                <div class="flex flex-col md:grid md:grid-cols-2 gap-5 w-full">
                    {dadosBiblioteca.horarios.map((unidade) => (
                        <div class="flex items-start gap-2 md:gap-3">
                            <div class="bg-red-100 text-[#C81D25] w-8 h-8 md:w-9 md:h-9 rounded-full flex items-center justify-center shrink-0">
                                <i class="fa-solid fa-clock text-[16px] md:text-[18px]"></i>
                            </div>
                            <div class="flex flex-col gap-0.5">
                                <h4 class="font-bold text-gray-800 text-sm md:text-base">{unidade.cidade}</h4>
                                <p class="text-xs md:text-sm text-gray-500 font-light leading-tight">{unidade.campi}</p>
                                <p class="text-xs md:text-sm text-gray-500 font-light leading-tight">{unidade.horario}</p>
                            </div>
                        </div>
                    ))}
                </div>
            </div>
        </div>

        <a href={dadosBiblioteca.linkRapido.url} target="_blank" class="text-white bg-[#BC1823] rounded-[20px] p-6 md:p-7 flex justify-between items-center gap-4 group shadow-sm hover:bg-[#a0141d] transition-colors">
            <div class="pr-2 md:pr-4">
                <h2 class="font-bold text-lg md:text-2xl leading-tight mb-1">{dadosBiblioteca.linkRapido.titulo}</h2>
                <p class="text-white/80 text-xs md:text-sm font-light leading-tight mt-2">{dadosBiblioteca.linkRapido.subtitulo}</p>
            </div>
            <i class="fa-solid fa-arrow-right text-2xl md:text-3xl"></i>
        </a>
    </div>
</LayoutBase>