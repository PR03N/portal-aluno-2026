---
import LayoutBase from "../layouts/LayoutBase.astro";
import dadosRegimento from "../data/direitos_deveres.json";
---

<LayoutBase mostrarBotaoVoltar={true}>
  <div
    class="flex flex-col gap-6 md:gap-7 lg:gap-8 max-w-full md:max-w-4xl lg:max-w-6xl w-full mx-auto pb-12 md:pb-16 px-2 md:px-4 lg:px-6"
  >
    <div class="mb-1 md:mb-3 lg:mb-5 text-left md:text-center">
      <h2 class="text-xl md:text-3xl font-bold text-gray-800">
        Direitos e Deveres
      </h2>
      <p
        class="text-sm md:text-base text-gray-500 font-medium mt-1 md:mt-2 max-w-3xl md:max-w-4xl mx-0 md:mx-auto"
      >
        Conheça a organização, os direitos e os deveres do estudante da UFSJ,
        fundamentados no Regimento Geral e resoluções do CONEP.
      </p>
    </div>

    <div
      class="bg-red-50 border border-red-100 rounded-[20px] md:rounded-3xl p-4 md:p-5 lg:p-6 mx-1 md:mx-auto md:w-full lg:w-11/12 flex gap-3 md:gap-4 items-start shadow-sm"
    >
      <i class="fa-solid fa-file-pdf text-[#BC1823] mt-0.5 text-lg shrink-0"
      ></i>
      <div class="flex flex-col">
        <p
          class="text-[13px] md:text-[14px] text-gray-700 leading-tight font-medium mb-3"
        >
          <span class="font-bold text-[#BC1823]">Documentos Oficiais:</span> Acesse
          e baixe as resoluções e o regimento na íntegra.
        </p>
        <div class="flex flex-wrap gap-2">
          {
            dadosRegimento.documentos.map((doc) => (
              <a
                href={doc.url}
                target="_blank"
                class="bg-white border border-red-100 text-[#BC1823] px-3 py-1.5 rounded-lg text-[11px] md:text-[12px] font-bold shadow-sm flex items-center gap-1.5 hover:bg-red-50 transition-colors"
              >
                <i class="fa-solid fa-download" /> {doc.titulo}
              </a>
            ))
          }
        </div>
      </div>
    </div>

    <div class="flex flex-col gap-6 px-1 md:px-0 mt-1">
      {
        dadosRegimento.categorias.map((sessao) => (
          <div class="flex flex-col gap-3">
            <h3 class="font-bold text-gray-800 text-[15px] md:text-[16px] flex items-center gap-2 border-b border-gray-200 pb-2">
              <i
                class={`fa-solid ${sessao.icone} ${sessao.cor} w-5 text-center text-[15px] md:text-[16px]`}
              />
              {sessao.categoria}
            </h3>

            <div class="flex flex-col gap-2">
              {sessao.itens.map((item) => (
                <details class="group bg-gray-50 border border-gray-100 rounded-[20px] shadow-sm overflow-hidden [&::-webkit-details-marker]:hidden">
                  <summary class="cursor-pointer p-4 flex justify-between items-center outline-none">
                    <span class="font-bold text-gray-700 text-[13px] pr-4 leading-tight">
                      {item.titulo}
                    </span>
                    <i class="fa-solid fa-chevron-down text-[#BC1823] group-open:rotate-180 transition-transform duration-300 shrink-0" />
                  </summary>

                  <div class="px-4 pb-5 pt-1">
                    <div
                      class="text-[13px] text-gray-600 leading-relaxed font-medium space-y-2"
                      set:html={item.descricao}
                    />

                    {item.base_legal && (
                      <div class="mt-4 bg-gray-100 p-3 rounded-xl border border-gray-200">
                        <p class="text-[10px] text-gray-500 font-bold uppercase tracking-wider mb-1 flex items-center gap-1.5">
                          <i class="fa-solid fa-book-bookmark" /> Base Normativa
                        </p>
                        <p class="text-[12px] text-gray-700 font-medium leading-tight">
                          {item.base_legal}
                        </p>
                      </div>
                    )}
                  </div>
                </details>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</LayoutBase>
