---
import LayoutBase from '../layouts/LayoutBase.astro';
import dadosCursos from '../data/campi.json';
---

<LayoutBase mostrarBotaoVoltar={true}>
  <div class="flex flex-col max-w-100 mx-auto pb-10">

    <div class="flex overflow-x-auto gap-2 px-2 pb-4 no-scrollbar">
      {dadosCursos.map((unidade, index) => (
        <button 
          class={`tab-btn whitespace-nowrap px-5 py-2 rounded-full text-sm font-bold border transition-colors ${index === 0 ? 'bg-[#BC1823] text-white border-[#BC1823]' : 'bg-gray-50 text-gray-500 border-gray-200'}`}
          data-target={`campus-${index}`}
        >
          {unidade.campus.split(' ')[0]} {unidade.campus.match(/\(([^)]+)\)/)?.[1] || ''} </button>
      ))}
    </div>

    <div class="px-2 pt-6">
      {dadosCursos.map((unidade, index) => (
        <div id={`campus-${index}`} class={`tab-content flex flex-col gap-3 ${index !== 0 ? 'hidden' : ''}`}>
          <h3 class="text-[#BC1823] font-bold text-sm uppercase tracking-wider mb-2 text-center">{unidade.campus}</h3>
          
          {unidade.cursos.map((curso) => (
            <details class="group bg-gray-50 border border-gray-100 rounded-[20px] shadow-sm overflow-hidden [&::-webkit-details-marker]:hidden">
              <summary class="cursor-pointer p-4 flex justify-between items-center outline-none">
                <span class="font-bold text-gray-800 text-[14px]">{curso.nome}</span>
                <i class="fa-solid fa-chevron-down text-gray-400 group-open:rotate-180 transition-transform"></i>
              </summary>
              <div class="px-4 pb-5 pt-1 border-t border-gray-100 mt-2">
                <div class="flex gap-2 mb-3 mt-2">
                  <span class="bg-red-100 text-[#BC1823] px-2 py-1 rounded text-[10px] font-bold uppercase">{curso.modalidade || "N/A"}</span>
                  <span class="bg-gray-200 text-gray-700 px-2 py-1 rounded text-[10px] font-bold uppercase"><i class="fa-regular fa-clock"></i> {curso.turno || "N/A"}</span>
                </div>
                <p class="text-[12px] text-gray-600 font-medium mb-4">{curso.descricao || "Descrição indisponível."}</p>
                <a href={curso.linkSite} target="_blank" class="block w-full text-center bg-[#BC1823] text-white text-[12px] font-bold py-2 rounded-lg">Ver Detalhes do Curso</a>
              </div>
            </details>
          ))}
        </div>
      ))}
    </div>

  </div>

  <script>
    // Lógica simples para trocar as abas
    const buttons = document.querySelectorAll('.tab-btn');
    const contents = document.querySelectorAll('.tab-content');

    buttons.forEach(button => {
      button.addEventListener('click', () => {
        // Reseta todos os botões
        buttons.forEach(btn => {
          btn.classList.remove('bg-[#BC1823]', 'text-white', 'border-[#BC1823]');
          btn.classList.add('bg-gray-50', 'text-gray-500', 'border-gray-200');
        });
        // Ativa o botão clicado
        button.classList.remove('bg-gray-50', 'text-gray-500', 'border-gray-200');
        button.classList.add('bg-[#BC1823]', 'text-white', 'border-[#BC1823]');

        // Esconde todos os conteúdos e mostra o selecionado
        contents.forEach(content => content.classList.add('hidden'));
        const targetId = button.getAttribute('data-target');
        if (targetId) {
          const targetElement = document.getElementById(targetId);
          if (targetElement) {
            targetElement.classList.remove('hidden');
          }
        } 
      });
    });
  </script>
</LayoutBase>