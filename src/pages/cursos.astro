---
import LayoutBase from "../layouts/LayoutBase.astro";
import dadosCursos from "../data/campi.json";
---

<LayoutBase mostrarBotaoVoltar={true}>
  <div
    class="flex flex-col max-w-full md:max-w-4xl lg:max-w-6xl w-full mx-auto pb-12 md:pb-16"
  >
    <div
      class="flex overflow-x-auto gap-2 px-2 md:px-4 pb-4 md:pb-5 no-scrollbar lg:justify-center"
    >
      {
        dadosCursos.map((unidade, index) => (
          <button
            class={`tab-btn whitespace-nowrap px-5 py-2 rounded-full text-sm font-bold border transition-colors ${index === 0 ? "bg-[#BC1823] text-white border-[#BC1823]" : "bg-gray-50 text-gray-500 border-gray-200"}`}
            data-target={`campus-${index}`}
          >
            {unidade.campus.split(" ")[0]}{" "}
            {unidade.campus.match(/\(([^)]+)\)/)?.[1] || ""}
          </button>
        ))
      }
    </div>

    <div class="px-2 md:px-4 pt-6 md:pt-8">
      {
        dadosCursos.map((unidade, index) => (
          <div
            id={`campus-${index}`}
            class={`tab-content flex flex-col gap-3 md:gap-4 lg:gap-5 ${index !== 0 ? "hidden" : ""}`}
          >
            <h3 class="text-[#BC1823] font-bold text-sm md:text-base uppercase tracking-wider mb-2 md:mb-3 text-center">
              {unidade.campus}
            </h3>

            {unidade.cursos &&
              unidade.cursos.map((curso) => (
                <details class="group bg-gray-50 border border-gray-100 rounded-[20px] shadow-sm overflow-hidden [&::-webkit-details-marker]:hidden">
                  <summary class="cursor-pointer p-4 flex justify-between items-center outline-none">
                    <span class="font-bold text-gray-800 text-[14px] md:text-[15px]">
                      {curso.nome}
                    </span>
                    <i class="fa-solid fa-chevron-down text-gray-400 group-open:rotate-180 transition-transform" />
                  </summary>
                  <div class="px-4 pb-5 pt-1 border-t border-gray-100 mt-2">
                    <div class="flex flex-wrap gap-2 mb-3 mt-2">
                      <span class="bg-red-100 text-[#BC1823] px-2 py-1 rounded text-[10px] font-bold uppercase">
                        {curso.modalidade || "N/A"}
                      </span>
                      {curso.turno && (
                        <span class="bg-gray-200 text-gray-700 px-2 py-1 rounded text-[10px] font-bold uppercase flex items-center gap-1.5">
                          <i class="fa-regular fa-clock" /> {curso.turno}
                        </span>
                      )}
                    </div>
                    <p class="text-[12px] md:text-[13px] text-gray-600 font-medium mb-4">
                      {curso.descricao || "Descrição indisponível."}
                    </p>

                    {curso.linkSite ? (
                      <a
                        href={curso.linkSite}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="block w-full text-center bg-[#BC1823] text-white text-[12px] md:text-[13px] font-bold py-2.5 rounded-lg hover:bg-[#9a121b] transition-colors"
                      >
                        Ver Detalhes do Curso
                      </a>
                    ) : (
                      <span class="block w-full text-center bg-gray-200 text-gray-500 text-[12px] md:text-[13px] font-bold py-2.5 rounded-lg">
                        Página do Curso Indisponível
                      </span>
                    )}
                  </div>
                </details>
              ))}
          </div>
        ))
      }
    </div>
  </div>

  <script>
    const buttons = document.querySelectorAll(".tab-btn");
    const contents = document.querySelectorAll(".tab-content");

    buttons.forEach((button) => {
      button.addEventListener("click", () => {
        buttons.forEach((btn) => {
          btn.classList.remove(
            "bg-[#BC1823]",
            "text-white",
            "border-[#BC1823]",
          );
          btn.classList.add("bg-gray-50", "text-gray-500", "border-gray-200");
        });
        button.classList.remove(
          "bg-gray-50",
          "text-gray-500",
          "border-gray-200",
        );
        button.classList.add("bg-[#BC1823]", "text-white", "border-[#BC1823]");

        contents.forEach((content) => content.classList.add("hidden"));
        const targetId = button.getAttribute("data-target");
        if (targetId) {
          const targetElement = document.getElementById(targetId);
          if (targetElement) {
            targetElement.classList.remove("hidden");
          }
        }
      });
    });
  </script>
</LayoutBase>
