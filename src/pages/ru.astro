---
import LayoutBase from '../layouts/LayoutBase.astro';
import dadosRu from '../data/rus.json';
---

<LayoutBase mostrarBotaoVoltar={true}>
    <div class="flex flex-col gap-5 max-w-100 mx-auto pb-10">

        <div class="px-2 mb-2">
            <h2 class="text-xl font-bold text-gray-800">Restaurante Universitário</h2>
            <p class="text-sm text-gray-500 font-medium mt-1">
                Confira os horários, valores e acesse o cardápio de cada unidade. O RU funciona apenas em dias letivos.
            </p>
        </div>

        <div class="bg-red-50 border border-red-100 rounded-[20px] p-4 mx-1 flex gap-3 items-start">
            <i class="fa-solid fa-circle-exclamation text-[#BC1823] mt-0.5 text-lg"></i>
            <p class="text-[13px] text-gray-700 leading-tight font-medium">
                <span class="font-bold text-[#BC1823]">Atenção:</span> Para entrar nos Restaurantes Universitários, é obrigatório apresentar a sua carteira estudantil.
            </p>
        </div>

        <div class="flex flex-col gap-4 px-1 mt-2">
            {dadosRu.map((unidade) => (
                <div class="bg-gray-50 border border-gray-100 rounded-[20px] p-5 shadow-sm flex flex-col">
                    
                    <div class="flex items-center gap-3 mb-4 border-b border-gray-200 pb-4">
                        <div class="bg-red-100 w-10 h-10 rounded-full flex items-center justify-center shrink-0">
                            <i class="fa-solid fa-utensils text-[#BC1823] text-[16px]"></i>
                        </div>
                        <div class="flex flex-col pr-2">
                            <span class="font-bold text-gray-800 text-[15px] leading-tight">{unidade.campus}</span>
                            <span class="text-[12px] text-gray-500 font-medium mt-0.5"><i class="fa-solid fa-map-pin mr-1"></i>{unidade.cidade}</span>
                        </div>
                    </div>

                    <div class="grid grid-cols-2 gap-3 mb-4">
                        {unidade.horarios.map((horario) => (
                            <div class="flex flex-col bg-white border border-gray-100 p-3 rounded-xl justify-center">
                                <span class="text-[10px] text-[#BC1823] font-bold uppercase tracking-wider mb-1 flex items-center gap-1.5"><i class="fa-regular fa-clock"></i>{horario.refeicao}</span>
                                <span class="text-[13px] text-gray-800 font-bold leading-tight">{horario.periodo}</span>
                                <span class="text-[10px] text-gray-500 font-medium mt-1 leading-tight">{horario.dias}</span>
                            </div>
                        ))}
                    </div>

                    <div class="bg-white border border-gray-100 rounded-xl p-3 mb-5">
                        <p class="text-[10px] text-gray-400 font-bold uppercase tracking-wider mb-2 border-b border-gray-100 pb-1">Valores da Refeição</p>
                        
                        <div class="flex justify-between items-center mb-2">
                            <span class="text-[12px] text-gray-600 font-medium pr-4 leading-tight">Discentes de graduação presencial (matriculados)</span>
                            <span class="text-[13px] text-[#BC1823] font-bold shrink-0">{unidade.valores.estudante}</span>
                        </div>
                        
                        <div class="flex justify-between items-center">
                            <span class="text-[11px] text-gray-500 pr-4 leading-tight">Servidores, terceirizados, visitantes e pós-graduação</span>
                            <span class="text-[12px] text-gray-800 font-bold shrink-0">{unidade.valores.outros}</span>
                        </div>
                    </div>

                    <a href={unidade.linkCardapio} target="_blank" class="w-full bg-[#BC1823] text-white text-[13px] font-bold py-3 rounded-xl flex items-center justify-center gap-2">
                        <i class="fa-solid fa-list"></i> Ver Cardápio
                    </a>

                </div>
            ))}
        </div>

    </div>
</LayoutBase>