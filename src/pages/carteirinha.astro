---
import LayoutBase from '../layouts/LayoutBase.astro';
import dadosCarteirinha from '../data/carteirinha.json';
---

<LayoutBase mostrarBotaoVoltar={true}>
    <div class="flex flex-col gap-4 max-w-100 mx-auto pb-6">
        
        <a href={dadosCarteirinha.solicitacao.url} target="_blank" class="bg-[#BC1823] text-white rounded-[20px] p-6 flex justify-between items-center group">
            <div class="pr-4">
                <h2 class="font-bold text-lg leading-tight mb-1">{dadosCarteirinha.solicitacao.titulo}</h2>
                <p class="text-white/80 text-xs font-light leading-tight mt-2">{dadosCarteirinha.solicitacao.subtitulo}</p>
            </div>
            <i class="fa-solid fa-arrow-right text-2xl"></i>
        </a>

        <div class="bg-gray-50 border border-gray-100 rounded-[20px] p-6 mt-2">
            <h3 class="text-sm text-gray-500 font-bold mb-5 flex items-center gap-2 uppercase tracking-wide">
                <i class="fa-solid fa-location-dot text-[#BC1823]"></i>Onde usar
            </h3>
            <div class="flex justify-evenly items-center px-2">
                {dadosCarteirinha.locaisDeUso.map((local) => (
                    <div class="flex flex-col items-center gap-2">
                        <div class="bg-red-100 text-[#BC1823] w-12 h-12 rounded-full flex items-center justify-center">
                            <i class={`fa-solid ${local.icone} text-xl`}></i>
                        </div>
                        <span class="text-[11px] font-bold text-gray-700 uppercase">{local.rotulo}</span>
                    </div>
                ))}
            </div>
        </div>

        <div class="bg-gray-50 border border-gray-100 rounded-[20px] p-6 mt-2">
            <h3 class="text-sm text-gray-500 font-bold mb-5 flex items-center gap-2 uppercase tracking-wide">
                <i class="fa-solid fa-circle-info text-[#BC1823]"></i> Importante
            </h3>
            
            <div class="flex flex-col gap-4">
                {dadosCarteirinha.informacoesImportantes.map((paragrafo) => (
                    <p class="text-[14px] text-gray-700 leading-relaxed font-medium" set:html={paragrafo} />
                ))}
            </div>
            
        </div>
    </div>
</LayoutBase>