---
import LayoutBase from '../layouts/LayoutBase.astro';
import dadosVidaAcademica from '../data/academico.json';
---

<LayoutBase mostrarBotaoVoltar={true}>
    <div class="flex flex-col gap-5 md:gap-6 lg:gap-8 max-w-full md:max-w-4xl lg:max-w-6xl w-full mx-auto pb-12 md:pb-16 px-2 md:px-4 lg:px-6">

        <div class="mb-2 md:mb-4 lg:mb-6 text-left md:text-center">
            <h2 class="text-xl md:text-3xl font-bold text-gray-800 tracking-tight">Estrutura Universitária</h2>
            <p class="text-sm md:text-base text-gray-500 font-medium mt-1 md:mt-2 max-w-3xl md:max-w-4xl mx-0 md:mx-auto">
                Conheça os principais órgãos, divisões e pró-reitorias que estruturam a UFSJ.
            </p>
        </div>

        <div class="flex flex-col lg:grid lg:grid-cols-2 gap-3 md:gap-4 lg:gap-6 px-1 md:px-0">
            {dadosVidaAcademica.map((orgao) => (
                <details class="group bg-gray-50 border border-gray-100 rounded-[20px] p-0 shadow-sm overflow-hidden [&::-webkit-details-marker]:hidden h-full">
                    
                    <summary class="cursor-pointer px-5 py-4 md:py-5 flex justify-between items-center outline-none hover:bg-gray-50 transition-colors">
                        <div class="flex items-center gap-3 md:gap-4">
                            <div class="bg-red-100 w-11 h-11 md:w-12 md:h-12 rounded-full flex items-center justify-center shrink-0">
                                <i class={`fa-solid ${orgao.icone} text-[#BC1823] text-lg md:text-xl`}></i>
                            </div>
                            <div class="flex flex-col pr-2">
                                <span class="font-bold text-gray-800 text-[14px] md:text-[15px] leading-tight">{orgao.titulo}</span>
                                {orgao.sigla && (
                                    <span class="text-[11px] md:text-[12px] text-[#BC1823] font-bold uppercase mt-0.5 tracking-wide">{orgao.sigla}</span>
                                )}
                            </div>
                        </div>
                        <i class="fa-solid fa-chevron-down text-gray-400 group-open:rotate-180 transition-transform duration-300 shrink-0"></i>
                    </summary>

                    <div class="px-5 pb-6 pt-2 border-t border-gray-100">
                        <p class="text-[13px] md:text-[14px] text-gray-600 leading-relaxed font-medium mb-4">
                            {orgao.descricao}
                        </p>

                        {orgao.topicos && orgao.topicos.length > 0 && (
                            <div class="pt-3 border-t border-gray-200">
                                <p class="text-[11px] md:text-[12px] text-gray-400 font-bold uppercase tracking-wider mb-3">Principais Ações e Programas</p>
                                <ul class="flex flex-col gap-2.5">
                                    {orgao.topicos.map((topico) => (
                                        <li class="flex items-start gap-2">
                                            <i class="fa-solid fa-check text-[#BC1823] text-[12px] md:text-[13px] mt-0.5 shrink-0"></i>
                                            <span class="text-[13px] md:text-[14px] text-gray-700 font-medium leading-tight">{topico}</span>
                                        </li>
                                    ))}
                                </ul>
                            </div>
                        )}
                    </div>
                </details>
            ))}
        </div>

    </div>
</LayoutBase>