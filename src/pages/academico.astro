---
import LayoutBase from '../layouts/LayoutBase.astro';
import dadosVidaAcademica from '../data/academico.json';
---

<LayoutBase mostrarBotaoVoltar={true}>
    <div class="flex flex-col gap-5 max-w-100 mx-auto pb-10">

        <div class="mb-2 px-2">
            <h2 class="text-xl font-bold text-gray-800">Vida Acadêmica</h2>
            <p class="text-sm text-gray-500 font-medium mt-1">Conheça os principais órgãos, divisões e pró-reitorias que estruturam a UFSJ.</p>
        </div>

        <div class="flex flex-col gap-3 px-1">
            {dadosVidaAcademica.map((orgao) => (
                <details class="group bg-gray-50 border border-gray-100 rounded-[20px] shadow-sm overflow-hidden [&::-webkit-details-marker]:hidden">
                    
                    <summary class="cursor-pointer p-5 flex justify-between items-center outline-none hover:bg-gray-100/50 transition-colors">
                        <div class="flex items-center gap-4">
                            <div class="bg-red-100 w-11 h-11 rounded-full flex items-center justify-center shrink-0">
                                <i class={`fa-solid ${orgao.icone} text-[#BC1823] text-lg`}></i>
                            </div>
                            <div class="flex flex-col pr-2">
                                <span class="font-bold text-gray-800 text-[14px] leading-tight">{orgao.titulo}</span>
                                {orgao.sigla && (
                                    <span class="text-[11px] text-[#BC1823] font-bold uppercase mt-0.5 tracking-wide">{orgao.sigla}</span>
                                )}
                            </div>
                        </div>
                        <i class="fa-solid fa-chevron-down text-gray-400 group-open:rotate-180 transition-transform duration-300 shrink-0"></i>
                    </summary>

                    <div class="px-5 pb-6 pt-2 border-t border-gray-100">
                        <p class="text-[13px] text-gray-600 leading-relaxed font-medium mb-4">
                            {orgao.descricao}
                        </p>

                        {orgao.topicos && orgao.topicos.length > 0 && (
                            <div class="pt-3 border-t border-gray-200">
                                <p class="text-[11px] text-gray-400 font-bold uppercase tracking-wider mb-3">Principais Ações e Programas</p>
                                <ul class="flex flex-col gap-2.5">
                                    {orgao.topicos.map((topico) => (
                                        <li class="flex items-start gap-2">
                                            <i class="fa-solid fa-check text-[#BC1823] text-[12px] mt-0.5 shrink-0"></i>
                                            <span class="text-[13px] text-gray-700 font-medium leading-tight">{topico}</span>
                                        </li>
                                    ))}
                                </ul>
                            </div>
                        )}
                    </div>
                </details>
            ))}
        </div>

    </div>
</LayoutBase>