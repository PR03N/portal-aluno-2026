---
import LayoutBase from '../layouts/LayoutBase.astro';
import dadosInicio from '../data/main_menu.json';
---

<LayoutBase mostrarBotaoVoltar={false}>
    <script src="../scripts/calendario.js"></script>

    <div class="grid grid-cols-2 gap-3 max-w-100 mx-auto">
        {dadosInicio.map((item) => {
            // Renderização condicional: pula o item se não houver link definido
            if (!item.link) return null;

            // Segurança dinâmica para links externos
            const relAttr = item.target === '_blank' ? 'noopener noreferrer' : undefined;

            if (item.tipo === 'calendario') {
                return (
                    <a href={item.link} target={item.target} rel={relAttr} class="col-span-2 bg-[#BC1823] text-white rounded-[20px] p-5">
                        <div class="flex justify-between items-start mb-4">
                            <div class="flex gap-3 items-center">
                                <i class={`fa-solid ${item.icone} text-3xl`}></i>
                                <div>
                                    <h2 class="font-bold text-lg">{item.titulo}</h2>
                                    <p class="text-xs text-white/80 font-light">{item.subtitulo}</p>
                                </div>
                            </div>
                            <i class="fa-solid fa-arrow-right text-xl"></i>
                        </div>
                        <div id="lista-calendario" class="ml-3 mt-4 flex flex-col">
                            <p class="text-white/70 text-[13px] animate-pulse">Carregando datas do calendário...</p>
                        </div>
                    </a>
                );
            }

            if (item.tipo === 'destaque') {
                return (
                    <a href={item.link} target={item.target} rel={relAttr} class="col-span-2 bg-[#BC1823] text-white rounded-[20px] p-5 flex justify-between items-center">
                        <div>
                            <h2 class="font-bold text-2xl leading-tight">{item.titulo}</h2>
                            <p class="text-xs font-light text-white/80 mt-1">{item.subtitulo}</p>
                        </div>
                        <i class="fa-solid fa-arrow-right text-xl"></i>
                    </a>
                );
            }

            if (item.tipo === 'padrao') {
                const tamanhoTitulo = (item as any).classeTitulo || "text-lg";
                return (
                    <a href={item.link} target={item.target} rel={relAttr} class="col-span-1 bg-[#BC1823] text-white rounded-[20px] p-4 flex flex-col justify-center min-h-30">
                        <i class={`fa-solid ${item.icone} text-3xl mb-2`}></i>
                        <h3 class={`font-bold ${tamanhoTitulo} leading-tight`} set:html={item.titulo} />
                        <p class="text-xs font-light text-white/80 mt-1 leading-tight">{item.subtitulo}</p>
                    </a>
                );
            }
        })}
    </div>
</LayoutBase>